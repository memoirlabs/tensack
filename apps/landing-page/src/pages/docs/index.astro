---
import BaseLayout from "../../layouts/BaseLayout.astro";

const docs = [
  {
    href: "/docs/overview",
    title: "Overview",
    body: "What sixpack is, where it fits, and what is implemented today.",
  },
  {
    href: "/docs/architecture",
    title: "Architecture",
    body: "The runtime shape: typed schema, readable append source, and private generated state.",
  },
  {
    href: "/docs/file-format",
    title: "File format",
    body: "Current `.6b` cache files and the target `engine/state.6pack` layout.",
  },
  {
    href: "/docs/commands",
    title: "CLI",
    body: "The intentionally small command surface available in the current binary.",
  },
];
---

<BaseLayout title="sixpack docs" description="Current sixpack documentation.">
  <article class="doc-page">
    <section class="doc-hero">
      <div class="doc-wrap">
        <p class="doc-kicker">/ docs</p>
        <h1 class="doc-title">Readable local storage, typed application code.</h1>
        <p class="doc-lead">
          These pages describe the current sixpack design and behavior. Planned
          work is called out separately so the docs stay honest about what ships
          now and what is still reserved.
        </p>
      </div>
    </section>

    <section class="doc-block">
      <div class="doc-wrap doc-card-grid">
        {docs.map((doc) => (
          <a class="doc-card" href={doc.href}>
            <span>{doc.href.replace("/docs/", "")}</span>
            <h2>{doc.title}</h2>
            <p>{doc.body}</p>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
